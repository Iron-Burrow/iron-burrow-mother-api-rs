# Copy this file to .env for local Docker Compose.
# For production, copy it to .env.production and pass it with
# docker compose --env-file .env.production -f compose.yaml -f compose.prod.yaml up -d

# Application
APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=3000
RUST_LOG=iron_burrow_mother_api_rs=info,tower_http=info

# Local Docker publish port. The container still listens on HTTP_PORT=3000.
HOST_HTTP_PORT=3000

# Postgres
POSTGRES_DB=ibdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Use the Docker service hostname when the API runs inside Compose.
DATABASE_URL=postgres://postgres:postgres@ibdb-postgres:5432/ibdb

# Price Indexer Query Layer. Optional for local development; asset detail
# still returns price.status="unavailable" when these are missing.
PRICE_INDEXER_URL=http://price-indexer:3010
PRICE_QL_INTERNAL_TOKEN=change-me-shared-internal-token
PRICE_INDEXER_TIMEOUT_MS=2000

# DeFi Intelligence Service. Optional for local development. Prediction routes
# return prediction_resolver_unavailable when DIS is missing or unreachable.
DIS_BASE_URL=http://dis:8000
DIS_REQUEST_TIMEOUT_MS=5000
DIS_RETRY_MAX_ATTEMPTS=2

# Bigwig Hub. Optional until the public balance endpoints are enabled.
# Mother reaches the Hub over iron-burrow-infra-client-net.
INFRA_GATEWAY_URL=http://infra-gateway-hub:8080
INFRA_GATEWAY_TOKEN=change-me-shared-infra-gateway-token
BIGWIG_REQUEST_TIMEOUT_MS=30000
BIGWIG_MAX_CONTRACT_ADDRESSES=20

# ERC-20 transfer search. Disabled until the public extraction route is wired.
ERC20_TRANSFERS_ENABLED=false
ERC20_TRANSFERS_MAX_TOKEN_FILTERS=20

# Production image tag used by compose.prod.yaml for the shared API/migration image.
# Use an immutable Git tag; production should not deploy from `latest`.
IRON_BURROW_MOTHER_API_TAG=v0.1.1

# Used only if running infra/caddy/Caddyfile.
CADDY_DOMAIN=api.ironburrow.com
