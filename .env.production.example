# Copy this file to .env.production and pass it with:
# docker compose --env-file .env.production -f compose.yaml -f compose.prod.yaml up -d

# Application
APP_ENV=production
RUST_LOG=iron_burrow_mother_api_rs=info,tower_http=info

# Production image tag used by compose.prod.yaml for the API and migration images.
# Use an explicit release tag for deploys; do not deploy production from `latest`.
IRON_BURROW_MOTHER_API_TAG=v0.1.0

# Postgres
POSTGRES_DB=ibdb
POSTGRES_USER=postgres
# Placeholder only. Replace with a long random URL-safe password before deployment.
POSTGRES_PASSWORD=change-me-long-random-url-safe-password

# Compose expands this from the Postgres variables above, so the password is set once.
# Use a URL-safe password, or percent-encode reserved URL characters before deployment.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@ibdb-postgres:5432/${POSTGRES_DB}

# Used only if running infra/caddy/Caddyfile.
CADDY_DOMAIN=api.ironburrow.com
