# Copy this file to .env.production and pass it with:
# docker compose --env-file .env.production -f compose.yaml -f compose.prod.yaml up -d

# Application
APP_ENV=production
# Use beta for private Beta deployments. Use alpha only while retaining the
# broader Production Alpha 1 route surface.
PUBLIC_API_SURFACE=beta
RUST_LOG=iron_burrow_mother_api_rs=info,tower_http=info

# Production image tag used by compose.prod.yaml for the shared API/migration image.
# Use an explicit release tag for deploys; do not deploy production from `latest`.
IRON_BURROW_MOTHER_API_TAG=v0.2.X

# Postgres
POSTGRES_DB=ibdb
POSTGRES_USER=postgres
# Placeholder only. Replace with a long random URL-safe password before deployment.
POSTGRES_PASSWORD=change-me-long-random-url-safe-password

# Compose expands this from the Postgres variables above, so the password is set once.
# Use a URL-safe password, or percent-encode reserved URL characters before deployment.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@ibdb-postgres:5432/${POSTGRES_DB}

# Price Indexer Query Layer. The price-indexer service should be reachable on
# iron-burrow-net and does not need to publish port 3010 to the host.
PRICE_INDEXER_URL=http://price-indexer:3010
PRICE_QL_INTERNAL_TOKEN=change-me-shared-internal-token
PRICE_INDEXER_TIMEOUT_MS=2000

# DeFi Intelligence Service. Retained as internal integration boilerplate.
# DIS should be reachable on iron-burrow-net without publishing its port.
DIS_BASE_URL=http://dis:8000
DIS_REQUEST_TIMEOUT_MS=5000
DIS_RETRY_MAX_ATTEMPTS=2

# Bigwig Hub latest-balance and ERC-20 transfer primitives. The Mother API
# container joins the client-only Bigwig network; migration containers do not.
INFRA_GATEWAY_URL=http://infra-gateway-hub:8080
INFRA_GATEWAY_TOKEN=change-me-shared-infra-gateway-token
BIGWIG_REQUEST_TIMEOUT_MS=30000
BIGWIG_MAX_CONTRACT_ADDRESSES=20

# ERC-20 transfer search. Required for the first private Beta release.
ERC20_TRANSFERS_ENABLED=true
ERC20_TRANSFERS_MAX_TOKEN_FILTERS=20

# Used only if running infra/caddy/Caddyfile.
CADDY_DOMAIN=api.ironburrow.com
